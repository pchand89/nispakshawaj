# This repo tracks the maglist-child theme where WordPress loads it.
# Ignore the surrounding WordPress install and local noise.
*

# Keep this file
!.gitignore
!.cpanel.yml

# Un-ignore path parents (required for gitignore negations)
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/maglist-child/
!wp-content/themes/maglist-child/**

# Editor/OS noise
.DS_Store
**/.DS_Store
.vscode/
.idea/
